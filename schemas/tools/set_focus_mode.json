{
  "$schema": "https://aios.dev/schemas/tool/v1",
  "id": "system.settings.set_focus_mode",
  "name": "Set Focus Mode",
  "description": "Enables or disables Do Not Disturb / Focus mode with an optional end time.",
  "version": "0.1.0",
  "category": "settings",
  "input": {
    "type": "object",
    "properties": {
      "enabled": {
        "type": "boolean",
        "description": "Whether to enable or disable focus mode"
      },
      "until": {
        "type": "string",
        "format": "date-time",
        "description": "Auto-disable at this time (optional, ISO 8601)"
      },
      "allow_contacts": {
        "type": "array",
        "items": { "type": "string" },
        "description": "Contact names or IDs that can still reach the user (optional)"
      }
    },
    "required": ["enabled"]
  },
  "output": {
    "type": "object",
    "properties": {
      "status": {
        "type": "string",
        "enum": ["activated", "deactivated", "failed"],
        "description": "Result status"
      },
      "active_until": {
        "type": "string",
        "format": "date-time",
        "description": "When focus mode will auto-disable"
      }
    }
  },
  "capabilities": ["settings.notifications.modify"],
  "risk_class": "low",
  "side_effects": ["modifies_notification_settings"],
  "rollback": {
    "supported": true,
    "method": "Disable focus mode"
  },
  "audit": {
    "log_input": true,
    "log_output": true,
    "retention_days": 30
  },
  "consent_level": "none"
}
